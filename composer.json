{
    "name": "krayin/rest-api",
    "license": "MIT",
    "authors": [
        {
            "name": "Devansh Bawari",
            "email": "devansh.bawari419@webkul.com"
        }
    ],
    "autoload": {
        "psr-4": {
            "Webkul\\RestApi\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Webkul\\RestApi\\Tests\\": "tests/"
        }
    },
    "require": {
        "php": "^8.2",
        "darkaonline/l5-swagger": "^9.0",
        "laravel/sanctum": "^4.0"
    },
    "require-dev": {
        "orchestra/testbench": "^10.0",
        "phpunit/phpunit": "^11.5"
    },
    "scripts": {
        "test": "phpunit",
        "test-coverage": "phpunit --coverage-text"
    },
    "extra": {
        "laravel": {
            "providers": [
                "Webkul\\RestApi\\Providers\\RestApiServiceProvider"
            ]
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
