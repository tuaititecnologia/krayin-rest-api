{
    "name": "tuaititecnologia/krayin-rest-api",
    "description": "Community-maintained fork of krayin/rest-api: the Krayin CRM REST API modernized for Laravel 12, with fixes across lead, contact, activity, mail, product and settings endpoints, plus a full test suite and CI.",
    "keywords": [
        "krayin",
        "crm",
        "rest-api",
        "api",
        "laravel",
        "sanctum",
        "webkul"
    ],
    "license": "MIT",
    "homepage": "https://github.com/tuaititecnologia/krayin-rest-api",
    "authors": [
        {
            "name": "Devansh Bawari",
            "email": "devansh.bawari419@webkul.com",
            "role": "Original author"
        },
        {
            "name": "Alejandro Sanchez",
            "email": "sanchezalejandroismael@gmail.com",
            "role": "Fork maintainer"
        }
    ],
    "support": {
        "issues": "https://github.com/tuaititecnologia/krayin-rest-api/issues",
        "source": "https://github.com/tuaititecnologia/krayin-rest-api"
    },
    "replace": {
        "krayin/rest-api": "self.version"
    },
    "autoload": {
        "psr-4": {
            "Webkul\\RestApi\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Webkul\\RestApi\\Tests\\": "tests/"
        }
    },
    "require": {
        "php": "^8.2",
        "darkaonline/l5-swagger": "^9.0",
        "laravel/sanctum": "^4.0"
    },
    "require-dev": {
        "guzzlehttp/guzzle": "^7.8",
        "orchestra/testbench": "^10.0",
        "phpunit/phpunit": "^11.5"
    },
    "scripts": {
        "test": "phpunit",
        "test-coverage": "phpunit --coverage-text",
        "test-integration": "phpunit --testsuite Integration"
    },
    "extra": {
        "laravel": {
            "providers": [
                "Webkul\\RestApi\\Providers\\RestApiServiceProvider"
            ]
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
